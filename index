  talk:['话术提词器','把专业解释压缩成导购能直接说的三行话术。'],
  close:['成交与离店留存','成交则回写订单，未成交则生成电子试戴清单和跟进任务。']
};
const options = {
  budget:['¥600 以下','¥600–999','¥1000–1499','¥1500–1999','¥2000 以上','自定义 ¥800–1200'],
  scene:['日常上学','办公网课','夜间驾驶','运动户外','老花远近切换'],
  preference:['轻薄不显厚','舒适不压鼻','低调百搭','显脸小','耐用好打理','时尚有设计感','无明显偏好']
};
const selected = {
  budget:'自定义 ¥800–1200',
  scene:['日常上学','办公网课'],
  preference:['轻薄不显厚','舒适不压鼻'],
  source:'manual'
};
const products = [
  {id:'A',name:'A 区 3 排 · 小方框钛架',score:92,price:'¥1,180',loc:'A 区 3 排 4 号柜',lens:'1.74 高折射率镜片',stock:'现货 2 副',reason:'小框型可减少边缘厚度，钛架更轻，适合 -8.00D。',warn:'预算刚好压线，需讲清厚度和重量收益。',tags:['小框','钛架','1.74','主推']},
  {id:'B',name:'B 区 1 排 · TR90 小圆框',score:88,price:'¥980',loc:'B 区 1 排 2 号柜',lens:'1.67 高折射率镜片',stock:'现货 3 副',reason:'轻量、预算友好，适合作为预算内备选方案。',warn:'边缘厚度会比 1.74 方案略明显。',tags:['轻量','预算内','小圆框']},
  {id:'C',name:'C 区 2 排 · 细边金属框',score:81,price:'¥1,090',loc:'C 区 2 排 1 号柜',lens:'1.74 可选',stock:'现货 1 副',reason:'外观更精致，适合低调百搭需求。',warn:'金属框需提醒鼻托调校，避免压鼻梁。',tags:['低调','金属','现货']},
  {id:'D',name:'A 区 5 排 · 小椭圆板材框',score:79,price:'¥860',loc:'A 区 5 排 3 号柜',lens:'1.67 高折射率镜片',stock:'现货 2 副',reason:'框型较小，价格友好，适合学生日常上课。',warn:'板材框稍厚，需现场试戴看脸型。',tags:['学生','低价','小框']},
  {id:'E',name:'D 区 1 排 · 轻商务半框',score:74,price:'¥1,260',loc:'D 区 1 排 5 号柜',lens:'1.74 高折射率镜片',stock:'现货 1 副',reason:'视觉更轻，适合希望成熟一点的学生。',warn:'半框对装配要求更高，需要验配师确认。',tags:['半框','轻商务','需确认']},
  {id:'F',name:'B 区 4 排 · 轻量小矩形框',score:76,price:'¥1,080',loc:'B 区 4 排 6 号柜',lens:'1.74 可选',stock:'现货 2 副',reason:'框宽较小、重量可控，适合替换被排除的大框类推荐。',warn:'款式偏低调，需看顾客是否觉得普通。',tags:['小矩形','低调','替补']},
  {id:'G',name:'C 区 4 排 · 学院风小框',score:73,price:'¥930',loc:'C 区 4 排 2 号柜',lens:'1.67 高折射率镜片',stock:'现货 1 副',reason:'学生感更强，价位更友好，适合排除成熟款后补位。',warn:'1.67 镜片边缘会略明显，需提前说明。',tags:['学院风','预算内','替补']}
];
let currentProduct = products[0];
let compareList = [];
let excludedList = [];
let currentTalk = 'need';
function toast(text){const el=$('#toast'); el.textContent=text; el.classList.add('show'); setTimeout(()=>el.classList.remove('show'),1700)}
function switchView(id){
  $$('.view').forEach(v=>v.classList.remove('active'));
  $('#'+id).classList.add('active');
  $$('.nav button').forEach(b=>b.classList.toggle('active',b.dataset.view===id));
  $$('.step').forEach(s=>s.classList.toggle('active',s.dataset.step===id));
  $('#pageTitle').textContent = labels[id][0];
  $('#pageSub').textContent = labels[id][1];
}
function renderPills(){
  const pills = [$('#rSph').value, selected.budget, ...selected.scene, ...selected.preference];
  $('#summaryPills').innerHTML = pills.map(p=>`<span class="pill">${p}</span>`).join('');
  $('#custDesc').textContent = `高度近视｜${selected.budget.replace('自定义 ','')}｜${selected.scene.join('/')}｜${selected.preference.join('/')}`;
  $('#sumBudget').textContent = selected.budget;
  $('#sumScene').textContent = selected.scene.join(' / ');
  $('#sumPreference').textContent = selected.preference.join(' / ');
}
function renderOptions(){
  Object.keys(options).forEach(group=>{
    const box = $(`[data-group="${group}"]`);
    box.innerHTML='';
    options[group].forEach(opt=>{
      const btn=document.createElement('button');
      const isSelected = Array.isArray(selected[group]) ? selected[group].includes(opt) : selected[group]===opt;
      btn.className='seg'+(isSelected?' selected':'');
      btn.textContent=opt;
      btn.onclick=()=>{
        if(group==='budget') selected[group]=opt;
        else{
          const arr=selected[group];
          if(arr.includes(opt)) selected[group]=arr.filter(x=>x!==opt);
          else if(arr.length<2) arr.push(opt);
          else {arr.shift(); arr.push(opt)}
        }
        renderOptions(); renderPills();
      };
      box.appendChild(btn);
    });
  });
}
function activeProducts(){
  return products.filter(p=>!excludedList.some(x=>x.id===p.id)).slice(0,5);
}
function renderProducts(){
  const visible = activeProducts();
  if(!visible.some(p=>p.id===currentProduct.id)) currentProduct = visible[0] || products[0];
  const box=$('#recoCards'); box.innerHTML='';
  visible.forEach(p=>{
    const card=document.createElement('div');
    card.className='glass-card'+(p.id===currentProduct.id?' selected':'');
    card.innerHTML=`<div class="score">${p.score}</div><div class="glass-img"><div class="glasses"><i></i></div></div><h3>${p.name}</h3><div class="meta">${p.tags.map(t=>`<span>${t}</span>`).join('')}</div><p>${p.reason}</p><div class="card-actions"><button data-action="talk">查看话术</button><button data-action="compare">加入对比</button><button data-action="exclude">排除类似款</button></div>`;
    card.onclick=(e)=>{
      const action=e.target.dataset.action;
      if(action){
        e.stopPropagation();
        currentProduct=p;
        renderProducts();
        renderDetail();
        if(action==='talk'){
          switchView('talk'); currentTalk='pro'; updateTalkActive(); renderTalk();
          toast('已跳转到该款专属话术');
        }
        if(action==='compare') addCompare(p);
        if(action==='exclude') openExcludeSheet(p);
        return;
      }
      currentProduct=p; renderProducts(); renderDetail();
    };
    box.appendChild(card);
  });
  renderCompareTray();
  renderExcludeLog();
}
function renderDetail(){
  $('#detailName').textContent=currentProduct.name;
  $('#detailPrice').innerHTML=`${currentProduct.price}<small>套餐预估</small>`;
  $('#detailLoc').textContent=currentProduct.loc;
  $('#detailLens').textContent=currentProduct.lens;
  $('#detailStock').textContent=currentProduct.stock;
  $('#detailReason').textContent=currentProduct.reason;
  $('#detailWarn').textContent=currentProduct.warn;
  $('#planRecoName').textContent=currentProduct.name.split('· ')[1] + ' + 1.74 镜片';
  $('#dealSku').textContent=currentProduct.name;
}
function addCompare(p){
  if(compareList.some(x=>x.id===p.id)){
    toast('这副已经在对比栏里');
  }else if(compareList.length>=3){
    toast('对比栏最多放 3 副，请先移除一副');
  }else{
    compareList.push(p);
    toast('已加入对比栏，可横向讲解差异');
  }
  renderCompareTray();
  const panel=$('#comparePanel'); if(panel) panel.scrollIntoView({behavior:'smooth',block:'start'});
}
function removeCompare(id){
  compareList = compareList.filter(p=>p.id!==id);
  renderCompareTray();
  toast('已从对比栏移除');
}
function renderCompareTray(){
  const box=$('#compareTray'); if(!box) return;
  const slots=[];
  compareList.forEach(p=>{
    slots.push(`<div class="compare-slot"><b>${p.name}</b><div class="cp-price">${p.price}</div><div class="cp-meta">${p.tags.join(' · ')}<br>${p.reason}</div><button class="remove" data-remove="${p.id}">移除</button></div>`);
  });
  for(let i=compareList.length;i<3;i++) slots.push(`<div class="compare-slot">待加入第 ${i+1} 副<br>点击镜架卡片上的“加入对比”</div>`);
  box.innerHTML=slots.join('');
  box.querySelectorAll('[data-remove]').forEach(btn=>btn.onclick=()=>removeCompare(btn.dataset.remove));
}
function openExcludeSheet(p){
  currentProduct=p;
  renderDetail();
  $('#excludeTarget').textContent = `排除：${p.name}`;
  $('#excludeSheet').classList.add('show');
  $('#excludePanel').scrollIntoView({behavior:'smooth',block:'start'});
  toast('请选择排除原因，系统会刷新推荐');
}
function excludeCurrent(reason){
  if(!excludedList.some(x=>x.id===currentProduct.id)) excludedList.push({id:currentProduct.id,name:currentProduct.name,reason});
  $('#excludeSheet').classList.remove('show');
  renderProducts();
  renderDetail();
  toast('已排除类似款，并补入下一候选');
}
function renderExcludeLog(){
  const box=$('#excludeLog'); if(!box) return;
  if(!excludedList.length){
    box.innerHTML='<div class="exclude-item"><b>暂无排除反馈</b><span>试戴后再记录</span></div>';
    return;
  }
  box.innerHTML=excludedList.map(x=>`<div class="exclude-item"><b>${x.name}</b><span>${x.reason}</span></div>`).join('');
}
function talkPack(){
  return {
    need:`1. 你这个度数最怕镜片边缘厚，所以我们先不看大框，优先看小框。
2. 你又要上课、网课戴得久，所以重量和鼻梁压力也要一起考虑。
3. 我先拿 3 副最符合“轻薄不显厚”的现货，你试戴以后我们再看价格方案。`,
    pro:`1. 同样是 -8.00D，框越大，镜片边缘越容易显厚。
2. 这副小方框配 1.74 镜片，厚度和重量会更可控。
3. 不是越贵越好，而是你的度数要先避开大框和低折射率方案。`,
    price:`1. 这套 ¥1,180 比预算内方案贵一些，主要差在折射率和镜架重量。
2. 对你这个度数来说，差别会体现在边缘厚度和鼻梁负担上。
3. 如果预算要压低，我也给你一套 ¥980 的方案，但镜片边缘会稍微明显一点。`,
    objection:`1. 没关系，今天试过的几副我帮你做成电子清单。
2. 里面会写清楚每副的价格、适合原因和厚度提醒，你回去可以慢慢比。
3. 我明天再问你一下，价位或款式想调整的话，我再按你的反馈重新筛。`
  }
}
function renderTalk(){ $('#talkText').value = talkPack()[currentTalk]; }
$$('.nav button').forEach(b=>b.onclick=()=>switchView(b.dataset.view));
$$('.step').forEach(s=>s.onclick=()=>switchView(s.dataset.step));
$$('.source').forEach(s=>s.onclick=()=>{
  $$('.source').forEach(x=>x.classList.remove('selected'));
  s.classList.add('selected');
  selected.source=s.dataset.source;
  $('#ocrBox').classList.toggle('show',s.dataset.source==='photo');
  toast(s.dataset.source==='photo'?'已模拟拍照识别，待人工确认':'已切换验光数据来源');
});
$('#simulatePhoto').onclick=()=>{document.querySelector('.source[data-source="photo"]').click();};
$('#startFilter').onclick=()=>switchView('filter');
$('#toRecommend').onclick=()=>{switchView('recommend'); renderProducts(); renderDetail();};
$('#backProfile').onclick=()=>switchView('profile');
$('#toPricing').onclick=()=>switchView('pricing');
$('#detailCompare').onclick=()=>addCompare(currentProduct);
$('#dislikeBtn').onclick=()=>openExcludeSheet(currentProduct);
$('#compareToPricing').onclick=()=>{switchView('pricing'); toast('已带着对比结果进入算账页');};
$('#clearCompare').onclick=()=>{compareList=[]; renderCompareTray(); toast('已清空对比栏');};
$$('[data-reason]').forEach(b=>b.onclick=()=>excludeCurrent(b.dataset.reason));
$('#toTalk').onclick=()=>{switchView('talk'); currentTalk='price'; updateTalkActive(); renderTalk();};
$('#copyQuote').onclick=()=>toast('报价说明已复制');
$('#copyTalk').onclick=()=>toast('当前话术已复制');
$('#toClose').onclick=()=>switchView('close');
$('#finishDeal').onclick=()=>toast('订单已生成，客户档案已回写中台');
$('#sendWechat').onclick=()=>toast('企微试戴清单已发送，中台已记录');
$('#setFollow').onclick=()=>toast('已设置明日 10:00 跟进提醒');
$('#resetDemo').onclick=()=>{
  selected.budget='自定义 ¥800–1200'; selected.scene=['日常上学','办公网课']; selected.preference=['轻薄不显厚','舒适不压鼻'];
  $('#rSph').value='-8.00D'; $('#lSph').value='-7.75D'; $('#cyl').value='-1.00D'; $('#pd').value='62mm';
  renderOptions(); renderPills(); toast('已恢复示例客户');
};
function updateTalkActive(){
  $$('.talk-tabs button').forEach(b=>b.classList.toggle('active',b.dataset.talk===currentTalk));
  $$('.scenario').forEach(b=>b.classList.toggle('active',b.dataset.talk===currentTalk));
}
$$('.talk-tabs button').forEach(b=>b.onclick=()=>{currentTalk=b.dataset.talk; updateTalkActive(); renderTalk();});
$$('.scenario').forEach(b=>b.onclick=()=>{currentTalk=b.dataset.talk; updateTalkActive(); renderTalk();});
['rSph','lSph','cyl','pd'].forEach(id=>$('#'+id).addEventListener('input',renderPills));
renderOptions(); renderPills(); renderProducts(); renderDetail(); renderTalk();
</script>
</body>
</html>
