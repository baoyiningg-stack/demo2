<script>
const $ = (s)=>document.querySelector(s);
const $$ = (s)=>Array.from(document.querySelectorAll(s));
const labels = {
  profile:['验光数据与基础诉求','导购只补充少量关键输入，系统用规则和库存完成专业推荐。'],
  filter:['硬性规则过滤','先过滤高度近视风险，再从现货库存中做推荐排序。'],
