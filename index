<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>工具2 Demo · 智能选品 · 提词 · 算账</title>
  <style>
    :root{
      --ink:#17323a;
      --soft:#50666d;
      --muted:#7b8d93;
      --paper:#f2eee7;
      --surface:#ffffff;
      --line:#e4d9c8;
      --line2:#efe7dc;
      --amber:#cf860f;
      --amber-deep:#6b4406;
      --amber-bg:#fbeac9;
      --green:#5e8f2a;
      --green-bg:#eaf2de;
      --petrol:#0f6e78;
      --danger:#c0392b;
      --purple:#6258c4;
      --shadow:0 18px 42px rgba(88,56,18,.12);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      min-width:1200px;
      background:var(--paper);
      color:var(--ink);
      font-family:"PingFang SC","Hiragino Sans GB","Microsoft YaHei",system-ui,sans-serif;
      line-height:1.58;
    }
    button,input,select,textarea{font:inherit}
    .app{display:grid;grid-template-columns:254px 1fr;min-height:100vh}
    .side{
      background:#2d261b;
      color:#f7ead8;
      padding:26px 18px;
      position:sticky;
      top:0;
      height:100vh;
    }
    .brand{font-weight:900;font-size:20px;line-height:1.25}
    .brand small{display:block;margin-top:8px;color:#cfb995;font-size:10px;letter-spacing:.16em}
    .nav{margin-top:32px;display:grid;gap:7px}
    .nav button{
      border:0;border-radius:10px;background:transparent;color:#d1b88e;
      text-align:left;padding:12px 12px;cursor:pointer;font-weight:800;font-size:13px;
    }
    .nav button.active,.nav button:hover{background:#5a3f18;color:#fff}
    .side-note{
      position:absolute;left:18px;right:18px;bottom:22px;
      border-top:1px solid rgba(255,255,255,.16);padding-top:14px;
      color:#dbc8a7;font-size:12px;
    }
    .main{padding:26px 34px 40px}
    .top{display:flex;align-items:flex-start;justify-content:space-between;gap:24px;margin-bottom:18px}
    .eyebrow{font-size:11px;letter-spacing:.16em;color:var(--amber);font-weight:900;text-transform:uppercase}
    h1{margin:6px 0 4px;font-size:30px;color:#2d261b;letter-spacing:0}
    .sub{font-size:13px;color:var(--soft)}
    .customer-card{
      background:var(--surface);border:1px solid var(--line);border-radius:14px;
      padding:13px 16px;min-width:330px;box-shadow:0 10px 24px rgba(88,56,18,.06);
      font-size:12px;color:var(--soft);
    }
    .customer-card b{display:block;color:#2d261b;font-size:15px;margin-bottom:3px}
    .summary-line{margin-top:8px;display:flex;flex-wrap:wrap;gap:6px}
    .pill{border-radius:999px;background:#fff6e8;color:#7a4b09;border:1px solid #ead4ad;padding:3px 8px;font-size:11px;font-weight:800}
    .flow{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:18px}
    .step{
      background:#fff;border:1px solid var(--line);border-radius:13px;padding:10px;min-height:82px;cursor:pointer;
    }
    .step.active{border-color:var(--amber);box-shadow:0 8px 18px rgba(207,134,15,.16)}
    .step b{display:block;font-size:12px;color:#2d261b}
    .step span{display:block;margin-top:5px;font-size:11px;color:var(--muted)}
    .view{display:none}.view.active{display:block}
    .layout{display:grid;grid-template-columns:1.18fr .82fr;gap:18px}
    .wide-layout{display:grid;grid-template-columns:1fr;gap:18px}
    .panel{
      background:var(--surface);border:1px solid #eadfce;border-radius:16px;padding:19px;box-shadow:var(--shadow);
    }
    .panel.flat{box-shadow:none}
    .panel h2{margin:0 0 5px;font-size:18px;color:#2d261b}
    .hint{margin:0 0 15px;font-size:12px;color:var(--muted)}
    .section-title{margin:16px 0 8px;color:#6d5b44;font-size:11px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}
    .source-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
    .source{
      border:1px solid var(--line);border-radius:13px;background:#fff;padding:13px;cursor:pointer;min-height:102px;position:relative;
    }
    .source.selected{border-color:var(--amber);background:#fffaf1}
    .source b{display:block;font-size:14px;color:#2d261b;margin-bottom:5px}
    .source span{font-size:12px;color:var(--soft)}
    .badge{display:inline-block;border-radius:999px;padding:2px 7px;font-size:10px;font-weight:900;margin-top:8px;background:#f4e8d5;color:#754b10}
    .badge.future{background:#eef1fa;color:#37316d}
    .field-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .field{display:flex;flex-direction:column;gap:6px}
    .field label{font-size:11px;color:var(--muted);font-weight:900}
    .field input,.field select{
      border:1px solid var(--line);border-radius:10px;padding:10px 11px;color:var(--ink);outline:none;background:#fff;
    }
    .field input:focus,.field select:focus,textarea:focus{border-color:var(--amber)}
    .seg-row{display:flex;flex-wrap:wrap;gap:8px}
    .seg{
      border:1px solid var(--line);background:#fff;color:var(--soft);border-radius:999px;padding:8px 12px;
      font-size:12px;font-weight:800;cursor:pointer;
    }
    .seg.selected{border-color:var(--amber);background:#fff5e2;color:var(--amber-deep)}
    .actions{display:flex;gap:9px;align-items:center;flex-wrap:wrap;margin-top:16px}
    .action{border:0;border-radius:10px;background:var(--amber);color:#fff;padding:10px 14px;font-weight:900;font-size:12px;cursor:pointer}
    .outline{border:1px solid var(--amber);border-radius:10px;background:#fff;color:var(--amber-deep);padding:9px 13px;font-weight:900;font-size:12px;cursor:pointer}
    .ghost{border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--soft);padding:9px 13px;font-weight:900;font-size:12px;cursor:pointer}
    .note{border-left:3px solid var(--amber);background:#fff9ef;border-radius:0 12px 12px 0;padding:12px 14px;color:#63491d;font-size:12.5px;line-height:1.7}
    .summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .summary{border:1px solid #efe2ce;background:#fffaf4;border-radius:12px;padding:12px;min-height:78px}
    .summary .k{font-size:11px;color:var(--muted);font-weight:900}.summary .v{font-size:13px;color:#2d261b;margin-top:5px;font-weight:800}
    .ocr-box{display:none;border:1px solid #eadfce;border-radius:14px;background:#fffaf4;padding:14px;margin-top:12px}
    .ocr-box.show{display:block}
    .ocr-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
    .ocr-head b{font-size:13px;color:#2d261b}.ocr-head span{font-size:11px;color:var(--green);font-weight:900}
    .confidence{height:8px;border-radius:999px;background:#efe4d5;overflow:hidden;margin-top:6px}.confidence i{display:block;height:100%;background:var(--green);width:92%}
    .risk-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .risk-card{border:1px solid var(--line);border-radius:14px;background:#fff;padding:15px}
    .risk-card h3{margin:0 0 9px;font-size:15px;color:#2d261b}
    .risk-list{display:grid;gap:8px}
    .risk{display:grid;grid-template-columns:26px 1fr;gap:9px;align-items:start;border-bottom:1px solid #f0e8dd;padding-bottom:8px}
    .risk:last-child{border-bottom:0;padding-bottom:0}
    .risk .icon{width:24px;height:24px;border-radius:50%;display:grid;place-items:center;font-size:12px;font-weight:900}
    .risk.reject .icon{background:#fbecea;color:var(--danger)}
    .risk.keep .icon{background:var(--green-bg);color:#2c4a0f}
    .risk b{font-size:13px;color:#2d261b}.risk span{display:block;font-size:12px;color:var(--soft);margin-top:2px}
    .filter-log{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:14px}
    .log{background:#fff;border:1px solid var(--line);border-radius:12px;padding:12px}.log b{font-size:22px;color:#2d261b}.log span{display:block;font-size:11px;color:var(--muted)}
    .reco-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:18px}
    .cards{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
    .glass-card{border:1px solid var(--line);border-radius:15px;background:#fff;padding:13px;cursor:pointer;position:relative;min-height:222px}
    .glass-card.selected{border-color:var(--amber);box-shadow:0 10px 22px rgba(207,134,15,.13)}
    .score{position:absolute;right:12px;top:12px;background:#fff5e2;color:var(--amber-deep);border:1px solid #ead4ad;border-radius:999px;padding:3px 8px;font-size:11px;font-weight:900}
    .glass-img{height:72px;border-radius:12px;background:linear-gradient(135deg,#fffaf2,#f0dcc0);margin-bottom:11px;display:grid;place-items:center;overflow:hidden}
    .glasses{position:relative;width:118px;height:34px}
    .glasses:before,.glasses:after{content:"";position:absolute;top:3px;width:42px;height:25px;border:4px solid #2d261b;border-radius:11px;opacity:.76}
    .glasses:before{left:4px}.glasses:after{right:4px}
    .glasses i{position:absolute;left:51px;right:51px;top:15px;height:4px;background:#2d261b;opacity:.76;border-radius:4px}
    .glass-card h3{margin:0 58px 4px 0;font-size:15px;color:#2d261b}
    .meta{display:flex;flex-wrap:wrap;gap:5px;margin:7px 0}.meta span{background:#f5eee4;color:#6b583f;border-radius:999px;padding:3px 7px;font-size:10px;font-weight:900}
    .glass-card p{margin:0;font-size:12px;color:var(--soft);line-height:1.65}
    .card-actions{display:flex;gap:7px;margin-top:11px}.card-actions button{border:1px solid var(--line);background:#fff;border-radius:9px;color:#6b583f;font-size:11px;font-weight:900;padding:7px 8px;cursor:pointer}.card-actions button:hover{border-color:var(--amber);background:#fffaf2}
    .feedback-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:18px;margin-top:18px}
    .compare-head{display:flex;align-items:center;justify-content:space-between;gap:10px}.compare-head small{font-size:11px;color:var(--muted);font-weight:800}
    .compare-tray{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:12px}
    .compare-slot{border:1px dashed #dfc6a3;border-radius:13px;background:#fffaf4;min-height:126px;padding:12px;display:flex;flex-direction:column;justify-content:center;color:#8a7458;font-size:12px;line-height:1.55}
    .compare-slot b{color:#2d261b;font-size:13px}.compare-slot .cp-price{font-size:18px;font-weight:900;color:#2d261b;margin:4px 0}.compare-slot .cp-meta{font-size:11px;color:var(--soft)}.compare-slot .remove{margin-top:8px;border:0;background:transparent;color:var(--danger);font-size:11px;font-weight:900;cursor:pointer;text-align:left;padding:0}
    .exclude-log{display:grid;gap:8px;margin-top:12px}.exclude-item{border:1px solid #f0e0c9;border-radius:11px;background:#fffaf4;padding:10px 11px;font-size:12px;color:var(--soft);display:flex;justify-content:space-between;gap:10px}.exclude-item b{color:#2d261b}.exclude-item span{color:var(--amber-deep);font-weight:900}
    .exclude-sheet{display:none;margin-top:12px;border:1px solid #ead4ad;border-radius:14px;background:#fffaf2;padding:13px}.exclude-sheet.show{display:block}.exclude-sheet b{display:block;font-size:13px;color:#2d261b;margin-bottom:8px}.reason-buttons{display:flex;gap:8px;flex-wrap:wrap}.reason-buttons button{border:1px solid #dfc6a3;background:#fff;border-radius:999px;padding:7px 10px;font-size:11px;font-weight:900;color:#6b583f;cursor:pointer}.reason-buttons button:hover{border-color:var(--amber);color:var(--amber-deep)}
    @media(max-width:860px){.feedback-grid{grid-template-columns:1fr}.compare-tray{grid-template-columns:1fr}}
    .detail{position:sticky;top:24px}
    .detail h3{margin:0 0 8px;font-size:17px;color:#2d261b}.detail .price{font-size:28px;color:#2d261b;font-weight:900}.detail .price small{font-size:12px;color:var(--muted);font-weight:800;margin-left:4px}
    .detail-row{display:grid;grid-template-columns:92px 1fr;gap:8px;border-top:1px solid #f0e6d8;padding:9px 0;font-size:12.5px}.detail-row b{color:#6a573e}.detail-row span{color:#2d261b;font-weight:700}
    .compare{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .plan{border:1px solid var(--line);border-radius:15px;background:#fff;padding:15px;min-height:260px;position:relative}
    .plan.recommend{border-color:var(--amber);background:#fffaf2}.plan.budget{border-color:var(--green);background:#fbfdf8}.plan.upgrade{border-color:#cbc5ef;background:#fbfaff}
    .plan .tagtop{display:inline-block;border-radius:999px;padding:3px 8px;font-size:10px;font-weight:900;margin-bottom:9px;background:#f2e6d6;color:#6b4406}
    .plan h3{margin:0 0 8px;font-size:16px;color:#2d261b}.plan .money{font-size:30px;font-weight:900;color:#2d261b;margin:5px 0}.plan p{font-size:12.2px;color:var(--soft);line-height:1.7;margin:0}.plan ul{list-style:none;padding:0;margin:12px 0 0;display:grid;gap:6px}.plan li{font-size:12px;color:var(--soft);padding-left:17px;position:relative}.plan li:before{content:"›";position:absolute;left:0;color:var(--amber);font-weight:900}
    .explain{margin-top:14px;border:1px dashed var(--amber);border-radius:14px;background:#fff;padding:14px;color:#63491d;font-size:12.5px;line-height:1.7}
    .talk-grid{display:grid;grid-template-columns:1fr .9fr;gap:18px}
    .talk-tabs{display:flex;gap:7px;border-bottom:1px solid var(--line);margin-bottom:13px}
    .talk-tabs button{border:0;background:transparent;border-bottom:2px solid transparent;color:var(--muted);padding:9px 5px;cursor:pointer;font-size:12px;font-weight:900}
    .talk-tabs button.active{border-bottom-color:var(--amber);color:#2d261b}
    textarea{width:100%;border:1px solid #e7d9c5;border-radius:12px;background:#fffaf4;padding:14px;color:#243f45;resize:vertical;min-height:312px;outline:none;font-size:13px;line-height:1.8}
    .scenario-list{display:grid;gap:9px}.scenario{border:1px solid var(--line);border-radius:12px;background:#fff;padding:12px;cursor:pointer}.scenario.active{border-color:var(--amber);background:#fffaf2}.scenario b{display:block;font-size:13px;color:#2d261b}.scenario span{font-size:12px;color:var(--soft)}
    .close-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
    .result-card{border:1px solid var(--line);border-radius:16px;background:#fff;padding:18px;min-height:360px}
    .result-card h3{margin:0 0 8px;font-size:18px;color:#2d261b}.result-card p{margin:0 0 12px;font-size:12.5px;color:var(--soft);line-height:1.7}
    .receipt{border:1px solid #efe2ce;border-radius:14px;background:#fffaf4;padding:14px;margin-top:13px}.receipt .r{display:flex;justify-content:space-between;border-bottom:1px solid #f0e8dc;padding:8px 0;font-size:12px}.receipt .r:last-child{border-bottom:0}.receipt b{color:#2d261b}.receipt span{color:var(--soft)}
    .wechat-card{border:1px solid #cfe1cd;border-radius:14px;background:#f9fdf6;padding:14px;margin-top:13px}.wechat-card b{display:block;color:#2c4a0f;margin-bottom:8px}.wechat-card .item{border-bottom:1px solid #e3efdf;padding:8px 0}.wechat-card .item:last-child{border-bottom:0}.wechat-card .item h4{margin:0;font-size:13px;color:#2d261b}.wechat-card .item span{font-size:12px;color:var(--soft)}
    .toast{position:fixed;right:28px;bottom:24px;background:#2d261b;color:#fff;border-radius:10px;padding:12px 15px;font-size:12px;opacity:0;transform:translateY(10px);transition:.18s;z-index:20}.toast.show{opacity:1;transform:none}
  </style>
</head>
<body>
<div class="app">
  <aside class="side">
    <div class="brand">工具2<br>智能选品 · 提词 · 算账<small>IN-STORE SALES DEMO</small></div>
    <nav class="nav">
      <button class="active" data-view="profile">01 验光与诉求</button>
      <button data-view="filter">02 规则过滤</button>
      <button data-view="recommend">03 推荐 5 副</button>
      <button data-view="pricing">04 智能算账</button>
      <button data-view="talk">05 话术提词</button>
      <button data-view="close">06 成交留存</button>
    </nav>
    <div class="side-note">真实场景：高度近视、预算有限的大学生。<br>目标：3 分钟完成专业推荐、算账与留存。</div>
  </aside>

  <main class="main">
    <div class="top">
      <div>
        <div class="eyebrow">Demo · 工具2 · 成交</div>
        <h1 id="pageTitle">验光数据与基础诉求</h1>
        <div id="pageSub" class="sub">导购只补充少量关键输入，系统用规则和库存完成专业推荐。</div>
      </div>
      <div class="customer-card">
        当前客户
        <b id="custName">客户 A-0421 · 大学生</b>
        <span id="custDesc">高度近视｜¥800–1200｜上学/网课｜轻薄不显厚</span>
        <div class="summary-line" id="summaryPills"></div>
      </div>
    </div>

    <div class="flow">
      <div class="step active" data-step="profile"><b>验光与诉求</b><span>手输 / 设备 / 拍照，价位、场景、核心偏好</span></div>
      <div class="step" data-step="filter"><b>规则过滤</b><span>高度近视风险、库存、预算、镜框尺寸</span></div>
      <div class="step" data-step="recommend"><b>推荐 5 副</b><span>货位、理由、套餐、试戴反馈</span></div>
      <div class="step" data-step="pricing"><b>智能算账</b><span>推荐方案、预算内方案、升级方案</span></div>
      <div class="step" data-step="talk"><b>话术提词</b><span>需求、专业、价格、异议处理</span></div>
      <div class="step" data-step="close"><b>成交留存</b><span>订单绑定或电子试戴清单</span></div>
    </div>

    <section id="profile" class="view active">
      <div class="layout">
        <div class="panel">
          <h2>01 · 验光数据来源</h2>
          <p class="hint">第一版可先支持手动输入；电子导入和拍照导入作为未来能力展示。拍照识别结果必须人工确认后才能进入推荐。</p>
          <div class="source-grid">
            <div class="source selected" data-source="manual"><b>手动输入</b><span>导购或验光师录入球镜、柱镜、轴位、瞳距。</span><div class="badge">MVP 可做</div></div>
            <div class="source" data-source="device"><b>电子验光单导入</b><span>从 ERP / 验光设备同步本次验光数据。</span><div class="badge future">后续接入</div></div>
            <div class="source" data-source="photo"><b>拍照识别导入</b><span>拍纸质验光单，OCR 识别后人工确认。</span><div class="badge future">未来能力</div></div>
          </div>
          <div class="ocr-box" id="ocrBox">
            <div class="ocr-head"><b>拍照识别结果 · 待人工确认</b><span>整体置信度 92%</span></div>
            <div class="note">系统已识别右眼 -8.00D、左眼 -7.75D、散光 -1.00、瞳距 62mm。低置信度字段会高亮，需导购或验光师确认后生效。</div>
            <div class="confidence"><i></i></div>
          </div>

          <div class="section-title">验光数据</div>
          <div class="field-row">
            <div class="field"><label>右眼球镜 SPH</label><input id="rSph" value="-8.00D"></div>
            <div class="field"><label>左眼球镜 SPH</label><input id="lSph" value="-7.75D"></div>
            <div class="field"><label>散光 CYL</label><input id="cyl" value="-1.00D"></div>
            <div class="field"><label>瞳距 PD</label><input id="pd" value="62mm"></div>
          </div>

          <div class="section-title">整单预期价位段</div>
          <div class="seg-row" data-group="budget"></div>

          <div class="section-title">用眼场景，最多选 2 个</div>
          <div class="seg-row" data-group="scene"></div>

          <div class="section-title">核心偏好，最多选 2 个</div>
          <div class="seg-row" data-group="preference"></div>

          <div class="actions">
            <button class="action" id="startFilter">确认信息，开始智能过滤</button>
            <button class="outline" id="simulatePhoto">模拟拍照导入</button>
            <button class="ghost" id="resetDemo">恢复示例客户</button>
          </div>
        </div>

        <div class="panel">
          <h2>导购只需要点几下</h2>
          <p class="hint">第一屏只保留“价位段、用眼场景、核心偏好”三类输入，避免过度打标。</p>
          <div class="summary-grid">
            <div class="summary"><div class="k">验光判断</div><div class="v" id="sumOptic">高度近视，需控制框型与镜片厚度</div></div>
            <div class="summary"><div class="k">价位段</div><div class="v" id="sumBudget"></div></div>
